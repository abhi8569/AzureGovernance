# =============================================================================
# EAIP - Enterprise Access Intelligence Platform
# Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are prefixed with EAIP_

# --- Microsoft Entra ID (Azure AD) ---
EAIP_TENANT_ID=your-tenant-id-here

# OPTIONAL — Leave empty for SSO via 'az login' (no app registration needed).
# Only set this if you have a custom app registration.
EAIP_CLIENT_ID=

# OPTIONAL — Leave empty for interactive auth.
# Only set if using client credentials (service principal) flow.
EAIP_CLIENT_SECRET=

# --- Database ---
# Path to the local DuckDB database file.
EAIP_DATABASE_PATH=./data/eaip.duckdb

# --- Parquet Output ---
# Directory for Parquet file exports (Hive-partitioned).
EAIP_PARQUET_OUTPUT_DIR=./data/parquet

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
EAIP_LOG_LEVEL=INFO

# --- Extraction Settings ---
# Max retry attempts for API calls
EAIP_MAX_RETRIES=5
# Page size for API pagination (max 999 for Graph)
EAIP_BATCH_SIZE=999

# --- Azure DevOps (Optional) ---
EAIP_DEVOPS_ORG=
EAIP_DEVOPS_PAT=

# --- SQL Server Deep Extraction (Optional) ---
# Comma-separated pyodbc connection strings for databases to audit.
# Example: Driver={ODBC Driver 18 for SQL Server};Server=myserver.database.windows.net;Database=mydb;Authentication=ActiveDirectoryInteractive
EAIP_SQL_CONNECTIONS=[]

# --- Analysis Services / Power BI XMLA (Optional) ---
# Comma-separated XMLA endpoint URLs.
# Example: powerbi://api.powerbi.com/v1.0/myorg/MyWorkspace
EAIP_AAS_SERVERS=[]

# --- Feature Flags (Optional) ---
EAIP_EXTRACT_ENTRA=true
EAIP_EXTRACT_KEYVAULT=true
EAIP_EXTRACT_STORAGE=true
EAIP_EXTRACT_SQL=true
EAIP_EXTRACT_FABRIC=true
EAIP_EXTRACT_DEVOPS=true
EAIP_EXTRACT_AAS=true
EAIP_EXTRACT_SHAREPOINT=false
EAIP_EXTRACT_TEAMS=false
EAIP_EXTRACT_NETWORKING=true
EAIP_EXTRACT_COSMOSDB=true

# --- Subscription / Resource Group Scan Scope (Optional) ---
# Pre-configure subscription IDs for --scan-subscription mode.
# Can also be passed via CLI: --subscription-ids sub-1 sub-2
EAIP_SUBSCRIPTION_IDS=[]

# Pre-configure resource group names to restrict the scan scope to.
# Can also be passed via CLI: --resource-groups rg-1 rg-2
EAIP_RESOURCE_GROUPS=[]

