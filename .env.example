# =============================================================================
# EAIP - Enterprise Access Intelligence Platform
# Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are prefixed with EAIP_

# --- Microsoft Entra ID (Azure AD) ---
EAIP_TENANT_ID=your-tenant-id-here
EAIP_CLIENT_ID=your-client-id-here
# Leave empty to use interactive SSO (browser login).
# Set to use client credentials (service principal) flow.
EAIP_CLIENT_SECRET=

# --- Database ---
# Path to the local DuckDB database file.
EAIP_DATABASE_PATH=./data/eaip.duckdb

# --- Parquet Output ---
# Directory for Parquet file exports (Hive-partitioned).
EAIP_PARQUET_OUTPUT_DIR=./data/parquet

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
EAIP_LOG_LEVEL=INFO

# --- Extraction Settings ---
# Max retry attempts for API calls
EAIP_MAX_RETRIES=5
# Page size for API pagination (max 999 for Graph)
EAIP_BATCH_SIZE=999

# --- Azure DevOps (Optional) ---
EAIP_DEVOPS_ORG=
EAIP_DEVOPS_PAT=

# --- SQL Server Deep Extraction (Optional) ---
# Comma-separated pyodbc connection strings for databases to audit.
# Example: Driver={ODBC Driver 18 for SQL Server};Server=myserver.database.windows.net;Database=mydb;Authentication=ActiveDirectoryInteractive
EAIP_SQL_CONNECTIONS=[]

# --- Analysis Services / Power BI XMLA (Optional) ---
# Comma-separated XMLA endpoint URLs.
# Example: powerbi://api.powerbi.com/v1.0/myorg/MyWorkspace
EAIP_AAS_SERVERS=[]

# --- Feature Flags (Optional — all true by default) ---
EAIP_EXTRACT_SHAREPOINT=true
EAIP_EXTRACT_TEAMS=true
EAIP_EXTRACT_NETWORKING=true
EAIP_EXTRACT_COSMOSDB=true
